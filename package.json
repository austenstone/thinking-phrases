{
  "name": "thinking-phrases",
  "version": "2.0.0",
  "description": "Live thinking phrases for VS Code — feeds, stocks, GitHub commits, earthquakes, weather, Hacker News, and more",
  "type": "module",
  "bin": {
    "thinking-phrases": "./bin/thinking-phrases.ts"
  },
  "files": [
    "bin/",
    "out/",
    "src/",
    "scripts/",
    "tips/",
    "configs/",
    "launchd/",
    "tsconfig.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/austenstone/thinking-phrases.git"
  },
  "homepage": "https://github.com/austenstone/thinking-phrases",
  "keywords": [
    "vscode",
    "thinking-phrases",
    "copilot",
    "feeds",
    "github",
    "stocks",
    "hacker-news",
    "earthquakes",
    "weather",
    "cli"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "start": "tsx bin/thinking-phrases.ts",
    "start:interactive": "tsx bin/thinking-phrases.ts --interactive",
    "start:dry-run": "tsx bin/thinking-phrases.ts --dry-run",
    "health": "tsx scripts/show-thinking-phrases-health.ts",
    "schedule": "zsh scripts/install-rss-updater.zsh",
    "schedule:trigger": "zsh scripts/trigger-thinking-phrases-scheduler.zsh",
    "schedule:remove": "zsh scripts/uninstall-rss-updater.zsh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "fast-xml-parser": "^5.4.2",
    "jsonc-parser": "^3.3.1",
    "openai": "^6.27.0",
    "picocolors": "^1.1.1",
    "tsx": "^4.19.0",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.3.5",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
