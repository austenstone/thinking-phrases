{
  "name": "thinking-phrases",
  "version": "1.0.0",
  "description": "Curated thinking phrase packs for VS Code and beyond — like loading screen tips for AI",
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "rss:dry-run": "tsx scripts/update-rss-settings.ts --dry-run",
