{
  "limit": 25,
  "mode": "replace",
  "target": "auto",
  "verbose": false,
  "debug": false,
  "feeds": [],
  "phraseFormatting": {
    "includeSource": true,
    "includeTime": true,
    "maxLength": 140
  },
  "githubModels": {
    "enabled": true,
    "model": "openai/gpt-4.1",
    "tokenEnvVar": "GITHUB_MODELS_TOKEN",
    "maxInputItems": 10,
    "maxTokens": 300,
    "maxPhrasesPerArticle": 2,
    "temperature": 0.2,
    "fetchArticleContent": true,
    "maxArticleContentLength": 6000
  },
  "stockQuotes": {
    "enabled": false,
    "symbols": [
      "MSFT",
      "NVDA",
      "TSLA",
      "AMZN",
      "GOOGL",
      "AMD"
    ],
    "includeMarketState": true
  },
  "hackerNews": {
    "enabled": false,
    "feed": "top",
    "maxItems": 10,
    "minScore": 50
  },
  "earthquakes": {
    "enabled": false,
    "zipCode": "",
    "minMagnitude": 4,
    "windowHours": 24,
    "limit": 10,
    "radiusKm": 500,
    "orderBy": "time"
  },
  "weatherAlerts": {
    "enabled": false,
    "zipCode": "",
    "area": "FL",
    "minimumSeverity": "moderate",
    "limit": 10
  },
  "customJson": {
    "enabled": false,
    "url": "",
    "itemsPath": "",
    "titleField": "title",
    "contentField": "summary",
    "linkField": "url",
    "sourceField": "",
    "sourceLabel": "",
    "dateField": "publishedAt",
    "idField": "id",
    "maxItems": 10
  },
  "githubActivity": {
    "enabled": true,
    "mode": "org-commits",
    "org": "github",
    "feedKind": "timeline",
    "maxItems": 50,
    "sinceHours": 1,
    "tokenEnvVar": "GITHUB_TOKEN"
  }
}
