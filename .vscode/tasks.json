		},
		{
			"label": "validate-github-commits-with-models",
			"type": "shell",
			"command": "./node_modules/.bin/tsc --noEmit && npm run start:dry-run -- --use-github --github-mode repo-commits --github-repo microsoft/vscode --github-max-items 1 --github-since-hours 168 --use-models --fetch-article-content --debug",
			"isBackground": false
		},
		{
			"label": "validate-github-org-feed",
			"type": "shell",
			"command": "./node_modules/.bin/tsc --noEmit && npm run start:dry-run -- --use-github --github-mode feed --github-feed-kind organization --github-org github --github-max-items 5",
